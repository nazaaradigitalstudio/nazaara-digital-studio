# Supabase (you already have these)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare Turnstile
# Site key is public (rendered in the browser); secret key is server-only.
# For local testing you can use Cloudflare's always-pass test keys:
#   site:   1x00000000000000000000AA
#   secret: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# WhatsApp fallback number (country code + number, digits only, no + or spaces)
# Example for India: 919999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Email notifications (Resend) - optional. Leave unset to disable.
# Get an API key at https://resend.com. To start fast, leave LEAD_NOTIFY_FROM unset
# (uses onboarding@resend.dev, which can only email your own Resend account address).
# For production, verify your domain in Resend and use e.g. "Nazaara Leads <leads@nazaara.studio>".
RESEND_API_KEY=
LEAD_NOTIFY_TO=you@nazaara.studio,aaryaveer@nazaara.studio
LEAD_NOTIFY_FROM=
